# --- Required ---

# Solana keypair used as the facilitator fee payer and signer.
# Accepts either:
#   - Base58-encoded secret (e.g. from `solana-keygen`), or
#   - JSON array of 64 bytes (e.g. from `solana-keygen ... --outfile`)
SVM_PRIVATE_KEY=

# Comma-separated list of Solana mainnet RPC URLs. The facilitator tries
# them in order and fails over on error.
RPC_URLS=https://api.mainnet-beta.solana.com

# Legacy single-RPC variable - still honored if RPC_URLS is unset.
# RPC_URL=https://api.mainnet-beta.solana.com

# --- Optional (sensible defaults) ---

# HTTP port for the facilitator API (/verify, /settle, /supported,
# /livez, /readyz). Prometheus metrics are served separately on 9464.
PORT=4022

# Log verbosity: debug | info | warn | error. Defaults to info.
LOG_LEVEL=info

# --- Security / deployment ---

# Set to "true" ONLY when the facilitator sits behind a trusted proxy
# (ALB, Nginx, Cloudflare, etc) that appends X-Forwarded-For. When false,
# the rate limiter keys off the real socket IP to prevent header spoofing.
TRUST_PROXY=false

# Comma-separated origins allowed for browser CORS. Empty / unset = no
# CORS headers (same-origin only). Use "*" to allow any origin — not
# recommended for production since /verify and /settle move funds.
# Example: https://app.chainflow.io,https://dashboard.chainflow.io
CORS_ALLOWED_ORIGINS=

# --- Compliance / audit ---

# Absolute path for the JSONL settle audit log. When unset, no audit
# records are written (a warning is logged at startup). Every attempted
# /settle produces exactly one line with requestId, payer, payTo, asset,
# amount, transaction sig, result, durationMs. fdatasync'd per write.
# Example: /var/log/chainflow/audit.log
AUDIT_LOG_PATH=
